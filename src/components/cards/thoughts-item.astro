---
import FormattedDate from "@components/misc/formatted-date.astro";

const { category, title, description, pubDate, slug } = Astro.props;
---

<a href={`/thoughts/${slug}`} class="group block">
	<article class="thought-row relative flex flex-col gap-2.5 py-4">
		<div class="flex flex-row items-center justify-between gap-4 text-xs text-content-muted font-medium">
			<span class="lowercase">{category}</span>
			<span>
				<FormattedDate date={pubDate.toString()} />
			</span>
		</div>
		<div class="flex flex-col gap-2">
			<h2 class="text-base sm:text-lg font-semibold text-content leading-snug tracking-[-0.018em] group-hover:text-content transition-colors duration-300 ease-[var(--ease-premium)]">
				{title}
			</h2>
			<p class="text-sm text-content-secondary leading-relaxed line-clamp-2">
				{description}
			</p>
		</div>
	</article>
</a>

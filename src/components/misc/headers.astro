---
import HeaderLink from "./header-link.astro";
import { menuItems } from "@data/index";
---

<nav
	class="fixed top-4 sm:top-6 left-1/2 -translate-x-1/2 z-50 flex items-center gap-1.5 sm:gap-6 px-4 py-2 sm:px-6 sm:py-3 rounded-full bg-white/80 backdrop-blur-xl border border-gray-200/60 shadow-lg shadow-black/5 transition-all duration-300 hover:bg-white/95 hover:shadow-xl hover:scale-[1.01] w-max max-w-[95vw]"
>
	<div
		class="flex flex-row gap-1.5 sm:gap-6 font-medium items-center text-xs sm:text-base"
	>
		{
			menuItems.map((item) => (
				<HeaderLink
					href={item.url}
					class="relative px-2 py-3 transition-colors hover:text-black whitespace-nowrap"
				>
					{item.label}
				</HeaderLink>
			))
		}
	</div>
</nav>

<div class="h-16 sm:h-20 w-full pointer-events-none"></div>

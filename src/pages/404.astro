---
import { Header } from "@components/misc";
import { BaseHead } from "@components/seo";
import { SITE_DESCRIPTION } from "@data/index";
import RootLayout from "@layouts/root-layout.astro";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="404 — page not found"
			description={SITE_DESCRIPTION}
		/>
	</head>

	<RootLayout>
		<Header />
		<div class="flex flex-col gap-6 mt-20 mb-16">
			<span class="text-xs font-semibold uppercase tracking-widest text-orange-500">404</span>
			<h1 class="text-4xl font-bold text-gray-900 tracking-tight">
				page not found
			</h1>
			<p class="text-lg text-gray-500 leading-relaxed max-w-prose">
				this page doesn't exist or was moved. nothing suspicious here — just a wrong turn.
			</p>
			<a
				href="/"
				class="inline-flex items-center gap-2 text-sm font-medium text-gray-900 hover:text-orange-500 transition-colors border-b border-gray-300 hover:border-orange-500 pb-0.5 w-fit"
			>
				&larr; back home
			</a>
		</div>
	</RootLayout>
</html>

---
import { Header } from "@components/misc";
import { BaseHead } from "@components/seo";
import RootLayout from "@layouts/root-layout.astro";

const roles = [
	{
		title: "Cyber Security ASA",
		company: "Deloitte",
		period: "May 2022 - May 2025",
		meta: [
			{ label: "Client", value: "Meta (Facebook)" },
			{ label: "Location", value: "Hyderabad, India" },
		],
		kicker: "Global security programs",
		focus: "Third-party risk, cryptographic governance, audit readiness",
		scope: ["Meta", "FIFA", "500+ assessments"],
		bullets: [
			"Managed 500+ third-party risk assessments for global clients like Meta and FIFA, evaluating security posture against NIST 800-53, SOC 2, and ISO 27001.",
			"Built a cryptographic governance program, defining standards for AWS KMS, Azure Key Vault, and HSMs.",
			"Conducted technical deep-dives on penetration test reports and secure SDLC policies to validate vendor controls.",
			"Technical lead for external audits, partnering with engineering teams to close findings and improve security maturity.",
		],
	},
	{
		title: "Analyst",
		company: "Metrics4 Analytics",
		period: "Jan 2020 - May 2022",
		meta: [{ label: "Location", value: "Hyderabad, India" }],
		kicker: "Security assurance foundation",
		focus: "Control reviews, risk documentation, remediation tracking",
		scope: ["IT risk", "SOX", "vendor reviews"],
		bullets: [
			"Supported IT security assessments for client applications, reviewing control alignment across NIST, ISO 27001, and SOX requirements.",
			"Documented gaps, risk findings, and remediation actions to help teams improve security posture and maintain audit-ready evidence.",
			"Helped maintain IT risk registers and policy exception workflows, including compensating controls and risk acceptance documentation.",
			"Coordinated with vendors and cross-functional teams on access controls, third-party security reviews, and high-priority security issue triage.",
		],
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Experience"
			description="Work history, certifications, and education for Keerthi Kovuru, a security analyst focused on third-party risk, cloud controls, and identity."
			image="/images/keerthi-og.png"
		/>
	</head>

	<RootLayout>
		<div id="navbar+title" class="page-flow">
			<Header />
			<main class="experience-flow">
				<section class="experience-hero">
					<h1 class="page-title">
						experience
					</h1>
				</section>

				<section class="experience-stack" aria-label="Work history">
					{
						roles.map((role, index) => (
							<article class="experience-card">
								<div class="experience-card-top">
									<span class="experience-count">
										{String(index + 1).padStart(2, "0")}
									</span>
									<span class="experience-period">{role.period}</span>
								</div>

								<div class="experience-card-grid">
									<div class="experience-role">
										<span class="experience-kicker">{role.kicker}</span>
										<h2>{role.company}</h2>
										<p>{role.title}</p>
										<div class="experience-meta">
											{role.meta.map((item) => (
												<div class="experience-meta-row">
													<span>{item.label}</span>
													<strong>{item.value}</strong>
												</div>
											))}
										</div>
									</div>

									<div class="experience-detail">
										<p class="experience-focus">{role.focus}</p>
										<div class="experience-scope">
											{role.scope.map((item) => (
												<span>{item}</span>
											))}
										</div>

										<ul class="experience-impact">
											{role.bullets.map((bullet) => (
												<li>{bullet}</li>
											))}
										</ul>
									</div>
								</div>
							</article>
						))
					}
				</section>

				<section class="education-card">
					<div>
						<span class="section-label">education</span>
						<h2>
							Osmania University
						</h2>
						<p>
							Electronics and Communication Engineering
						</p>
					</div>
					<div class="education-detail">
						<span>2016 - 2020</span>
						<strong>
								Bachelor of Engineering (BE)
						</strong>
						<span>Grade: 8.10</span>
					</div>
				</section>
			</main>
		</div>
	</RootLayout>
</html>

---
import { getCollection } from "astro:content";
import { ThoughtsItem } from "@components/cards";
import { Header } from "@components/misc";
import { BaseHead } from "@components/seo";
import RootLayout from "@layouts/root-layout.astro";

const thoughts = (await getCollection("thought")).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="thoughts"
			description="Practical notes on cloud security, identity, AI governance, and third-party risk."
		/>
	</head>

	<RootLayout>
		<div id="navbar+title" class="page-flow">
			<Header />
			<div class="page-hero">
				<h1 class="page-title">
					thoughts
				</h1>
			</div>

			{
				thoughts.length === 0 ? (
					<p class="text-content-muted text-sm">No posts yet.</p>
				) : (
					<div class="thought-list">
						{thoughts.map((thought) => (
							<ThoughtsItem
								category={thought.data.category}
								title={thought.data.title}
								description={thought.data.description}
								pubDate={thought.data.pubDate}
								slug={thought.id}
							/>
						))}
					</div>
				)
			}
		</div>
	</RootLayout>
</html>

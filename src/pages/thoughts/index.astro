---
import { ThoughtsItem } from "@components/cards";
import { Header } from "@components/misc";
import { BaseHead } from "@components/seo";
import { getCollection } from "astro:content";
import RootLayout from "@layouts/root-layout.astro";

const thoughts = (await getCollection("thought")).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="thoughts"
			description="Insights on cloud security, governance, and the future of risk management."
		/>
	</head>
	<RootLayout>
		<div id="navbar+title" class="flex flex-col w-full gap-6">
			<Header />
			<h1 class="w-full text-[min(12vw,72px)] font-medium tracking-tight mb-6">
				Thoughts
			</h1>

			{
				thoughts.length === 0 ? (
					<p class="text-gray-400 text-sm">no posts yet.</p>
				) : (
					thoughts.map((thought) => (
						<ThoughtsItem
							category={thought.data.category}
							title={thought.data.title}
							pubDate={thought.data.pubDate}
							slug={thought.slug}
						/>
					))
				)
			}
		</div>
	</RootLayout>
</html>
